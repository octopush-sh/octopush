{
  "name": "octopush",
  "version": "0.1.13",
  "description": "The IDE for Agentic Developers — eight arms, zero wasted tokens.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "cd src-tauri && cargo build --release --bin octopush-pty-server && cd .. && tauri build",
    "release": "node scripts/release.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
