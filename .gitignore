# Dependencies
node_modules/
.pnp/
.pnp.js

# Build output
dist/
dist-ssr/
build/
*.local

# Rust / Cargo
src-tauri/target/
src-tauri/gen/schemas/
# Octopush is a binary application — Cargo.lock is tracked so reproducible
# builds across machines pin the exact dep tree (avoids the Tauri Rust/JS
# minor-version mismatch the bundler refuses to build through).

# Build-generated triple-suffixed sidecar binaries (created by build.rs)
src-tauri/octopush-pty-server-*

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.zed/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.local
.env.*.local
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Octopus runtime data
~/.octopus-sh/
octopus.db
octopus.db-journal

# Brainstorming companion (visual mockups)
.superpowers/

# Claude Code local state
.claude/settings.local.json
.claude/scheduled_tasks.lock

